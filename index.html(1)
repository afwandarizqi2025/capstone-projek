<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <style>
        /* --- CSS Dasar --- */
        :root {
            --warna-hijau: #2E7D32;
            --warna-hijau-muda: #4CAF50;
            --warna-putih: #ffffff;
            --warna-abu: #f4f4f4;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background-color: var(--warna-abu);
            color: #333;
            line-height: 1.6;
        }

        a { text-decoration: none; color: inherit; }

        /* --- Header --- */
        header {
            background: var(--warna-hijau);
            color: var(--warna-putih);
            padding: 1rem 0;
            position: sticky;
            top: 0;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
            z-index: 100;
        }

        .container {
            width: 90%;
            max-width: 1100px;
            margin: auto;
        }

        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo { font-size: 1.5rem; font-weight: bold; }

        /* --- Hero Section --- */
        .hero {
            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), 
                        url('https://images.unsplash.com/photo-1448375240586-dfd8d395ea6c?auto=format&fit=crop&w=1600');
            background-size: cover;
            background-position: center;
            height: 350px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            color: white;
        }

        .hero h1 { font-size: 2.5rem; margin-bottom: 10px; }
        .hero h2 { font-size: 1.5rem; margin-bottom: 20px; }

        .btn {
            background: var(--warna-hijau-muda);
            color: white;
            padding: 10px 25px;
            border-radius: 5px;
            font-weight: bold;
            transition: 0.3s;
        }
        .btn:hover { background: var(--warna-hijau); }

        /* --- Section --- */
        .section { padding: 40px 0; }
        
        .section-title {
            text-align: center;
            margin-bottom: 30px;
            color: var(--warna-hijau);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* --- Grid --- */
        .grid-3 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
        }

        .card {
            background: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            border-left: 5px solid var(--warna-hijau);
        }

        /* --- Tabel --- */
        .table-responsive {
            background: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #eee;
        }

        th {
            background-color: var(--warna-hijau);
            color: white;
        }

        /* --- Footer --- */
        footer {
            background: #333;
            color: white;
            text-align: center;
            padding: 20px 0;
            margin-top: 40px;
        }

        .footer-info { margin-top: 10px; font-size: 0.9rem; color: #ccc; }

        /* --- Responsive --- */
        @media (max-width: 768px) {
            .hero h1 { font-size: 1.8rem; }
            .logo { font-size: 1.2rem; }
        }
    </style>
</head>
<body>

    <!-- Navigasi -->
    <header>
        <div class="container navbar">
            <div class="logo">🏠 Desa {{ nama_desa }} | RT {{ data_rt }} / RW {{ data_rw }}</div>
            <div>
                <a href="#struktur" style="margin-left: 15px;">Struktur</a>
                <a href="#info" style="margin-left: 15px;">Info</a>
            </div>
        </div>
    </header>

    <!-- Halaman Utama -->
    <section class="hero">
        <h1>Selamat Datang</h1>
        <h2>Website Resmi Desa {{ nama_desa }} RT {{ data_rt }} RW {{ data_rw }}</h2>
        <a href="#profil" class="btn">Lihat Profil</a>
    </section>

    <!-- Section Profil -->
    <section id="profil" class="section container">
        <h2 class="section-title">Profil Wilayah</h2>
        <div class="grid-3">
            <div class="card">
                <h3>📍 Lokasi</h3>
                <p>Desa {{ nama_desa }} terletak di kawasan pedesaan yang nyaman dan strateggis.</p>
            </div>
            <div class="card">
                <h3>👥 Jumlah Warga</h3>
                <p>RT {{ data_rt }} RW {{ data_rw }} memiliki +50 Kepala Keluarga (KK).</p>
            </div>
            <div class="card">
                <h3>🤝 Gotong Royong</h3>
                <p>Masyarakat aktif dalam kegiatan kerja bakti dan Ronda Malam.</p>
            </div>
        </div>
    </section>

    <!-- Section Struktur -->
    <section id="struktur" class="section container">
        <h2 class="section-title">Struktur Organisasi</h2>
        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>No</th>
                        <th>Nama Pengurus</th>
                        <th>Jabatan</th>
                        <th>Periode</th>
                    </tr>
                </thead>
                <tbody>
                    {% for p in pengurus %}
                    <tr>
                        <td>{{ p.no }}</td>
                        <td>{{ p.nama }}</td>
                        <td>{{ p.jabatan }}</td>
                        <td>{{ p.periode }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>

    <!-- Section Info & Pengumuman -->
    <section id="info" class="section container" style="background-color: #e8f5e9;">
        <h2 class="section-title">Info & Pengumuman</h2>
        <div class="grid-3">
            {% for news in pengumuman %}
            <div class="card">
                <h3>{{ news.judul }}</h3>
                <small style="color: #666;">📅 {{ news.tanggal }}</small>
                <p style="margin-top: 10px;">{{ news.isi }}</p>
            </div>
            {% endfor %}
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="container">
            <h3>Hubungi Kami</h3>
            <p class="footer-info">Desa {{ nama_desa }} RT {{ data_rt }} RW {{ data_rw }}</p>
            <p class="footer-info">Email: kontributor.ngarak@gmail.com</p>
            <p style="margin-top: 20px;">&copy; 2024 - Created with Python</p>
        </div>
    </footer>

</body>
</html>

